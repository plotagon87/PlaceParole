# PlaceParole Environment Variables Template
# Instructions:
# 1. Copy this file to .env
# 2. Fill in YOUR actual credentials
# 3. Never commit .env to git (it's in .gitignore)

# ================================================================
# DATABASE CONFIGURATION
# ================================================================
DB_HOST=localhost
DB_NAME=placeparole
DB_USER=root
DB_PASS=

# ================================================================
# GMAIL/EMAIL CONFIGURATION
# Setup: https://myaccount.google.com/security
# Enable 2-Step Verification and generate an App Password
# ================================================================
GMAIL_USERNAME=your-gmail@gmail.com
GMAIL_PASSWORD=your-app-password-here
GMAIL_FROM_NAME=PlaceParole Market Platform

# ================================================================
# TWILIO CONFIGURATION (WhatsApp)
# Setup: https://console.twilio.com
# Get from: Account Info > Account SID and Auth Token
# ================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# ================================================================
# APPLICATION CONFIGURATION
# ================================================================
APP_ENV=development
APP_DEBUG=true
BASE_URL=/PlaceParole
